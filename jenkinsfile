nexusArtifactUploader artifacts: [[artifactId: 'myapp1', classifier: '', file: 'target/myapp1.war', type: 'war']], credentialsId: 'nexus-cred', groupId: 'com.rc', nexusUrl: '52.66.195.218:8081/', nexusVersion: 'nexus3', protocol: 'http', repository: 'maven-snapshots', version: '1.0-SNAPSHOT'
}

stage('deploy to tomcat'){

    deploy adapters: [tomcat9(alternativeDeploymentContext: '', credentialsId: 'credtom', path: '', url: 'http://52.66.54.177:8080/manager/text')], contextPath: '/myapp1', war: 'target/myapp1.war'
}
    
