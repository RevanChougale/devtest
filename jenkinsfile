node{
    stage('Git-Clone'){
        git branch: 'main', credentialsId: 'git-cred', url: 'https://github.com/RevanChougale/devtest.git' 
    }
    stage('maven-build'){
        sh 'mvn clean package'
    }
stage('SonarQube Analysis') {
    withSonarQubeEnv('Sonar-Server-9.9.3') { // Jenkins Sonar server name
    sh '/usr/share/maven/bin/mvn sonar:sonar -Dsonar.projectKey=devtest -Dsonar.projectName=devtest'
        }
    
}
